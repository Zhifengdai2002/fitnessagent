MODEL_API_KEY=your_model_api_key_here
MODEL_BASE_URL=https://api.z.ai/api/paas/v4/
MODEL_THINKING_TYPE=enabled
YOUTUBE_API_KEY=your_youtube_api_key_here
MODEL_NAME=glm-4.5-air

# Optional. If set, FitnessAgent stores runtime state in MySQL.
# If unset or unavailable, it falls back to data/app_state.json.
DATABASE_URL=mysql+pymysql://fitness_user:fitness_password@127.0.0.1:3306/fitness_agent?charset=utf8mb4
FITNESS_AGENT_USER_ID=demo-user

# Optional. Redis is a short-lived cache for active session state.
# MySQL/JSON remain the durable source of truth.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_STATE_TTL_SECONDS=604800
REDIS_CACHE_TTL_SECONDS=86400

# Optional. Vector database backend for exercise/food RAG.
# RAG_BACKEND=auto uses Milvus when configured, otherwise local JSON index.
# Set RAG_BACKEND=milvus after Milvus is running and indexed.
RAG_BACKEND=auto
MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_EXERCISE_COLLECTION=fitness_exercises
MILVUS_FOOD_COLLECTION=fitness_foods
